<?xml version="1.0" encoding="UTF-8" ?>
<persistence xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">
    <persistence-unit name="u1w3d5">
        <class>AntoninoPalazzolo.entities.Utente</class>
        <class>AntoninoPalazzolo.entities.Catalogo</class>
        <class>AntoninoPalazzolo.entities.Rivista</class>
        <class>AntoninoPalazzolo.entities.Libro</class>
        <class>AntoninoPalazzolo.entities.Prestito</class><!--tabelle nel database -->
        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:postgresql://localhost:5432/catalogo"/>
            <!-- value= numero porta del database + /nomedatabase(in questo caso gestioneeventi -->
            <property name="jakarta.persistence.jdbc.user" value="postgres"/>
            <!-- value= valore di default -->
            <property name="jakarta.persistence.jdbc.password" value="1234"/>
            <!-- password impostata all'inizio -->
            <property name="jakarta.persistence.jdbc.driver" value="org.postgresql.Driver"/>
            <property name="hibernate.hbm2ddl.auto" value="update"/>
            <!-- Quest'ultima impostazione servirà per creare/aggiornare automaticamente le tabelle all'avvio dell'applicazione -->
        </properties>
    </persistence-unit>
</persistence>